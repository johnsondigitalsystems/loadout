<?xml version="1.0" encoding="utf-8"?>
<!--
  LoadOut launcher mark for the Wear OS companion. Adaptive icon
  foreground; the background lives in `ic_launcher_background.xml`.

  Design intent: a brass-colored ring with internal crosshair plus a
  small charcoal centre dot. Reads as "scope reticle" at icon scale,
  staying recognisably LoadOut without depending on a pixel-art logo
  the Play Store would reject as too generic.

  Adaptive-icon foregrounds use a 108dp viewport with a 72dp safe
  zone (the centre 66.67%); everything outside the safe zone may be
  cropped on round / rounded-square / squircle masks. We keep all
  load-bearing strokes inside the 72dp circle.

  Color: 0xFFC46E21 is the LoadOut brass tone; 0xFF2A2A2A is the
  charcoal. Both pulled from the wider brand palette so the launcher
  reads as part of the same family as the phone app icon.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
        android:width="108dp"
        android:height="108dp"
        android:viewportWidth="108"
        android:viewportHeight="108">

    <!-- Outer ring: brass annulus, ~2dp wide. Sits inside the
         safe zone so it survives every mask shape. -->
    <path
        android:fillColor="#C46E21"
        android:pathData="M54,28
                         A26,26 0 1,1 54,80
                         A26,26 0 1,1 54,28 Z
                         M54,32
                         A22,22 0 1,0 54,76
                         A22,22 0 1,0 54,32 Z" />

    <!-- Vertical crosshair stroke. Stops short of the centre to leave
         room for the dot. -->
    <path
        android:fillColor="#C46E21"
        android:pathData="M52.5,32 h3 v14 h-3 z
                         M52.5,62 h3 v14 h-3 z" />

    <!-- Horizontal crosshair stroke. -->
    <path
        android:fillColor="#C46E21"
        android:pathData="M32,52.5 h14 v3 h-14 z
                         M62,52.5 h14 v3 h-14 z" />

    <!-- Inner dot — central mark. Charcoal so it reads against both
         the ring and a possible white background mask. -->
    <path
        android:fillColor="#2A2A2A"
        android:pathData="M54,50
                         A4,4 0 1,1 54,58
                         A4,4 0 1,1 54,50 Z" />
</vector>
