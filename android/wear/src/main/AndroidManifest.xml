<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          xmlns:tools="http://schemas.android.com/tools">

    <uses-feature android:name="android.hardware.type.watch" />

    <!-- Allow this watch app to be paired with a phone app that does not
         itself ship a watch app of its own. Without this flag a Wear OS 3+
         device will refuse to install the standalone watch app. -->
    <uses-permission android:name="com.google.android.wearable.permission.RECEIVE_DATA_FROM_NODE" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.DeviceDefault"
        tools:targetApi="30">

        <!-- Required by every Wear OS app. Tells the system whether the
             watch app can run independently or always needs the phone app
             present. We mark `false` because LoadOut features depend on
             the phone-side reloading database. -->
        <meta-data
            android:name="com.google.android.wearable.standalone"
            android:value="false" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:taskAffinity=""
            android:theme="@android:style/Theme.DeviceDefault">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Stub Data Layer listener. Currently no-ops on every callback;
             enable & implement when phone <-> watch features land. The
             intent filters below are commented out so the receiver does
             not steal events away from the phone module. -->
        <service
            android:name=".PhoneDataLayerListener"
            android:exported="true">
            <!--
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.DATA_CHANGED" />
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <data android:scheme="wear" android:host="*" android:pathPrefix="/loadout/" />
            </intent-filter>
            -->
        </service>
    </application>
</manifest>
