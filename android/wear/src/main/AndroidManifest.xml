<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          xmlns:tools="http://schemas.android.com/tools">

    <uses-feature android:name="android.hardware.type.watch" />

    <!-- Allow this watch app to be paired with a phone app that does not
         itself ship a watch app of its own. Without this flag a Wear OS 3+
         device will refuse to install the standalone watch app. -->
    <uses-permission android:name="com.google.android.wearable.permission.RECEIVE_DATA_FROM_NODE" />

    <!-- Vibrator access for the stage timer haptics. Granted automatically
         on Wear OS but the manifest line is required for the runtime call
         to succeed on emulators and some hardened OEM ROMs. -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.DeviceDefault"
        tools:targetApi="30">

        <!-- Required by every Wear OS app. Tells the system whether the
             watch app can run independently or always needs the phone app
             present. We mark `false` because LoadOut features depend on
             the phone-side reloading database. -->
        <meta-data
            android:name="com.google.android.wearable.standalone"
            android:value="false" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:taskAffinity=""
            android:theme="@android:style/Theme.DeviceDefault">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Wearable Data Layer listener. Receives DataItem updates and
             Messages from the phone, scoped to the `/loadout/` path
             prefix so we don't intercept events meant for other Wear OS
             apps the user may have installed. The path-prefix filter is
             required by the Wearable runtime — without it the OS won't
             dispatch DATA_CHANGED / MESSAGE_RECEIVED events to us at
             all.

             The class lives in the `bridge` sub-package; the activity-
             level orphan that used to live at the wear/ root has been
             replaced by `bridge/PhoneDataLayerListener.kt`. -->
        <service
            android:name=".bridge.PhoneDataLayerListener"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.DATA_CHANGED" />
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <data android:scheme="wear" android:host="*" android:pathPrefix="/loadout/" />
            </intent-filter>
        </service>
    </application>
</manifest>
