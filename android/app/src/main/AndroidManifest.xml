<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Location permissions for the Pro "use my location" weather fetch on
         the ballistics Environment section. Coarse permission is sufficient
         for fetching weather; fine is requested as a fallback so handsets
         that already grant fine don't downgrade. -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

    <!-- Bluetooth permissions (Pro feature: pair with Kestrel weather meters
         and Garmin chronographs). On Android 12+ (API 31+) these are split
         into two distinct runtime permissions; on earlier API levels the
         legacy BLUETOOTH + BLUETOOTH_ADMIN are still required and Play Store
         Console implicitly maps the new permissions back. We declare
         `neverForLocation` on BLUETOOTH_SCAN so the OS knows we are not
         trying to derive the user's location from BLE beacons — this lets
         us avoid prompting for ACCESS_FINE_LOCATION solely for BLE scanning
         on API 31+. ACCESS_FINE_LOCATION is still declared above for the
         existing weather-fetch feature. -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
                     android:usesPermissionFlags="neverForLocation" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH"
                     android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN"
                     android:maxSdkVersion="30" />

    <!-- Biometric unlock (fingerprint / Face Unlock / iris on supported
         devices). Used solely to gate the app's HomeScreen behind a
         local biometric prompt when the user opts into Settings →
         Account → "Unlock with biometrics". The local_auth plugin
         relies on USE_BIOMETRIC for API 28+; USE_FINGERPRINT remains
         declared for the long tail of older devices that still ship
         only the legacy fingerprint API. See lib/services/biometric_service.dart. -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.USE_FINGERPRINT" />

    <!-- Camera permission. Used by:
         1. Photo Import (handwritten-notebook OCR feature, free-tier).
         2. Recipe QR Scanner (peer-to-peer recipe import via mobile_scanner).
         The runtime prompt is triggered by the respective plugins
         (image_picker / mobile_scanner). On Android 12+ the system also
         needs the manifest declaration. The matching iOS string lives in
         ios/Runner/Info.plist as NSCameraUsageDescription. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <application
        android:label="LoadOut"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <!-- Universal/App Links for email-link sign-in -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="https"
                      android:host="loadout-precision-reloading.web.app"
                      android:pathPrefix="/auth/"/>
                <data android:scheme="https"
                      android:host="loadout-precision-reloading.firebaseapp.com"
                      android:pathPrefix="/auth/"/>
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
