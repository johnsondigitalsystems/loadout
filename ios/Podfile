platform :ios, '15.5'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  # share_handler_ios depends on share_handler_ios_models, which the
  # plugin author publishes as a side-by-side pod under
  # `share_handler_ios/ios/Models/`, NOT in the standard plugin root
  # the way most federated Flutter plugins do. CocoaPods can't auto-
  # discover it from the central CDN, so without this explicit path
  # reference `pod install` fails with:
  #   [!] Unable to find a specification for `share_handler_ios_models`
  #       depended upon by `share_handler_ios`.
  # The same line is required again on the ShareExtension target once
  # that target gets added in Xcode (see ios/ShareExtension/README.md
  # step 7) — keep the two in lockstep.
  pod 'share_handler_ios_models', :path => '.symlinks/plugins/share_handler_ios/ios/Models'

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      # Force every pod to the same deployment target so Xcode doesn't
      # complain about pods set to iOS 9.0. Bumped to 15.5 because
      # google_mlkit_commons 0.11.x (transitive of
      # google_mlkit_text_recognition 0.15.x) requires iOS 15.5.
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.5'
      # Xcode 14+ ships with User Script Sandboxing on by default, which
      # blocks the CocoaPods header-symlink scripts and produces
      # "sandbox is not in sync with the Podfile.lock" build failures.
      config.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'
    end
  end
end
